enum EMANICONINFO
{
	ACF_NEWINFO		= 0x0001,
	ACF_LOOP		= 0x0010,
	ACF_UPBODY		= 0x0100,	// UPBODY 录脗脝脙.		// UP DOWN 脌脤 录脗脝脙 戮脠碌脡 掳忙驴矛麓脗 碌冒脝煤脝庐路脦 脌眉脙录麓脵.
	ACF_DOWNBODY	= 0x0200,	// UP脌脤 戮酶掳铆 DOWN赂赂 录脗脝脙 碌脡 掳忙驴矛 UP脌潞 DOWN驴隆 驴碌脟芒脌禄 鹿脼戮脝戮脽 脟脩麓脵.
	ACF_SZNAME		= 128,
	ACF_DIV			= 8,
	ACF_STRIKE		= 9,
};

// Added by janzs420 | add new version for animation bin
struct SAnimation
{
	//enum { VERSION = 0x0102, };
	enum { VERSION = 0x0103, };

	// animation information
	SPositionKey	*m_pPositionKeys;	//	脌脤碌驴 驴隆麓脧脜掳.
	UINT			m_cPositionKeys;
	
	SRotateKey		*m_pRotateKeys;		//	脠赂脌眉 驴隆麓脧脜掳.
	UINT			m_cRotateKeys;
	
	SScaleKey		*m_pScaleKeys;		//	脜漏卤芒 驴隆麓脧脜掳.
	UINT			m_cScaleKeys;
	
	SMatrixKey		*m_pMatrixKeys;		// Matrix
	UINT			m_cMatrixKeys;

	SQuatPosKey*	m_pQuatPosKeys;		// Quaternion 脜脳陆潞脝庐 脟脪 掳脥脌脤麓脵..  驴脧录潞碌脟赂茅 Matrix麓脗 禄莽驴毛 戮脠 脟脪 掳脥脌脫.
	UINT			m_cQuatPosKeys;
	D3DXQUATERNION*	m_pQuatOrigRot;		// 录酶录枚脟脩 脠赂脌眉.. 戮脝脕脰 驴酶脕露脌脤麓脵. MIX 陆脙赂赂 禄莽驴毛脟脩麓脵. ~!!

	TSTRING		m_strBone;
	DxBoneTrans		*pBoneToAnimate;	//	脌没驴毛碌脡 BONE 掳煤 驴卢掳谩.

	DWORD			m_dwCurKey;
	float			m_fDivFullTime;		// Opitimize - 驴酶路隆麓脗 脌脤 掳陋 1.f/m_pMatrixKeys[m_cMatrixKeys-1].fTime
	float			m_fMatrixKeys;		// Opitimize - 驴酶路隆麓脗 脌脤 掳陋 m_cMatrixKeys

	SAnimation() :
			m_pPositionKeys(NULL),
			m_cPositionKeys(0),
			m_pScaleKeys(NULL),
			m_cScaleKeys(0),
			m_pRotateKeys(NULL),
			m_cRotateKeys(0),
			m_pMatrixKeys(NULL),
			m_cMatrixKeys(0),
			m_pQuatPosKeys(NULL),
			m_cQuatPosKeys(0),
			m_pQuatOrigRot(NULL),

			pBoneToAnimate(NULL),
			m_dwCurKey(0),
			m_fDivFullTime(0.f),
			m_fMatrixKeys(0.f)
	{
	}

	~SAnimation()
	{
		SAFE_DELETE_ARRAY(m_pPositionKeys);
		SAFE_DELETE_ARRAY(m_pRotateKeys);
		SAFE_DELETE_ARRAY(m_pScaleKeys);
		SAFE_DELETE_ARRAY(m_pMatrixKeys);
		SAFE_DELETE_ARRAY(m_pQuatPosKeys);
		SAFE_DELETE_ARRAY(m_pQuatOrigRot);

		// do NOT delete pToAnimate
	}

	void SetTime ( float fTime, float fWeight, BOOL bFirst );
	void SetMix ( float fTime );

	UINT GetThisKey ( float fTime ) const;
	const SMatrixKey* GetMapThisKey ( float fGlobalTime ) const;

	void SetMatrix ( UINT iKey );
	void SetMatrix ( const SMatrixKey* pMatrixKey )	{ pBoneToAnimate->matRot = pMatrixKey->mat; }

	void ConvertMatToQuat();

	HRESULT SaveToFile ( CSerialFile &SFile );
	HRESULT LoadFromFile ( CSerialFile &SFile, const DxSkeleton* pSkeleton );
	HRESULT Load_0100( CSerialFile &SFile, const DxSkeleton* pSkeleton );
	HRESULT Load_0101( CSerialFile &SFile, const DxSkeleton* pSkeleton );
	//Added by XMEN2 | 11-8-2012 | add new version for animation bin
	HRESULT Load_0102( CSerialFile &SFile, const DxSkeleton* pSkeleton );
	HRESULT Load( CSerialFile &SFile, const DxSkeleton* pSkeleton );
};

struct SANIMCONINFO_101
{
	TCHAR			m_szName[ACF_SZNAME];		//	脌脤赂搂.
	TCHAR			m_szSkeletion[ACF_SZNAME];	//	禄脌麓脵卤脥 脌脤赂搂.

	DWORD			m_dwFlag;					//	卤芒脜赂 录脫录潞.
	DWORD			m_dwSTime;					//	陆脙脌脹 陆脙掳拢.
	DWORD			m_dwETime, m_dwETimeOrig;	//	鲁隆 陆脙掳拢.
	DWORD			m_UNITTIME;					//	脜掳麓脺脌搂 陆脙掳拢.

	EMANI_MAINTYPE	m_MainType;
	EMANI_SUBTYPE	m_SubType;

	WORD			m_wDivCount;				//	驴隆麓脧赂脼脌脤录脟 潞脨脟脪 脜掳 掳鹿录枚.
	WORD			m_wDivFrame[ACF_DIV];		//	驴隆麓脧赂脼脌脤录脟 潞脨脟脪 脜掳碌茅..

	SANIMCONINFO_101()
	{
		memset( m_szName, 0, sizeof(TCHAR)*ACF_SZNAME );
		memset( m_szSkeletion, 0, sizeof(TCHAR)*ACF_SZNAME );
	}
};

